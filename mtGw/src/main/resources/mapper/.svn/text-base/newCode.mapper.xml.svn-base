<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="mtgw.sql.cache.newcode">
    <select id="findAllNewCode" resultType="java.lang.String">
        select code from bps_conf_newcode
    </select>

    <select id="findNewCode" parameterType="java.lang.String" resultType="java.lang.Integer">
        select count(1) from bps_conf_newcode where code=#{code}
    </select>
</mapper>