package com.nantian.nbp.flow.engine.service.api.exception;

/**
* 用于业务明确失败外抛异常场景
* */
public class BizException extends FlowException{
    public BizException(String errCode, String errMsg) {
        super(errCode, errMsg);
    }

    public BizException(String errCode, String errMsg, Throwable throwable) {
        super(errCode, errMsg, throwable);
    }

    public BizException(String errCode, String feTranCode, String message, Throwable throwable) {
        super(errCode, feTranCode, message, throwable);
    }
}
