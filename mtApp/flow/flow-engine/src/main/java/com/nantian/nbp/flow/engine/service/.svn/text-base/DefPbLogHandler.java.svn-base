package com.nantian.nbp.flow.engine.service;

import com.nantian.nbp.base.model.PbLog;
import com.nantian.nbp.flow.engine.service.api.PbLogHandler;
import com.nantian.nbp.flow.engine.service.api.context.FeContext;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

public class DefPbLogHandler implements PbLogHandler {

    private static final Logger LOGGER = LoggerFactory.getLogger(DefPbLogHandler.class);

    @Override
    public void handle(PbLog pbLog, FeContext feContext) {
        LOGGER.info("{}",pbLog);
    }
}
