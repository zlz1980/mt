server:
  port: 8083
  undertow:
    # IO线程数，执行非阻塞任务，默认值每个CPU核心一个线程
    io-threads: 8
    # 工作线程数，执行请求阻塞请求，取值为系统负载
    worker-threads: 16
    # 缓冲区大小，空间值越小利用越充分
    buffer-size: 8192
spring:
  application:
    name: mtapp

