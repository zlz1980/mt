package com.nantian.nbp.flowengine.model;

/**
* Try-Cache 组件
* @author Administrator
*/
public class TryModel extends AstModel {

	/** try分支 */
	private AstList tryBranch = null;
	/** catch节点 */
	private AstModel catchUnit = null;
	/** cache分支 */
	private AstList catchBranch = null;

	public AstList getTryBranch() {
		return tryBranch;
	}

	public void setTryBranch(AstList tryBranch) {
		this.tryBranch = tryBranch;
	}

	public AstList getCatchBranch() {
		return catchBranch;
	}

	public void setCatchBranch(AstList catchBranch) {
		this.catchBranch = catchBranch;
	}
	public AstModel getCatchUnit() {
		return catchUnit;
	}
	public void setCatchUnit(AstModel catchUnit) {
		this.catchUnit = catchUnit;
	}
}
