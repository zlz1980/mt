package com.nantian.nbp.flow.engine.service.api.context;

public enum RetType {

    /** 成功 */
    SUCCESS("SUCCESS"),
    /** 失败 */
    FAILED("FAILED"),
    /** 未明 */
    UNKNOWN("UNKNOWN");
    private final String type;

    RetType(String type) {
        this.type = type;
    }

    public String getType() {
        return type;
    }
}
