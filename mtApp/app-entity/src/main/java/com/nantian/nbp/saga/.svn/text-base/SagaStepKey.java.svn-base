package com.nantian.nbp.saga;

public class SagaStepKey {
    /** 业务编号 */
    private final String bizId;
    /** 步骤号 */
    private final String stepNo;

    public SagaStepKey(String bizId, String stepNo) {
        this.bizId = bizId;
        this.stepNo = stepNo;
    }

    public String getBizId() {
        return bizId;
    }

    public String getStepNo() {
        return stepNo;
    }
}
