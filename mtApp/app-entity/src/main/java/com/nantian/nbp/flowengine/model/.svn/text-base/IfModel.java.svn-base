package com.nantian.nbp.flowengine.model;

/**
* if 组件
* @author pengw at Jul 26, 2020 12:07:37 AM
* @version V2.0
*/
public class IfModel extends AstModel {
	
	/**
	 * 
	 */
	private static final long serialVersionUID = 1L;
	/** if分支 */
	private AstList ifBranch = null;
	/** else分支 */
	private AstList elseBranch = null;

	public AstList getIfBranch() {
		return ifBranch;
	}

	public AstList getElseBranch() {
		return elseBranch;
	}

	public void setIfBranch(AstList ifBranch) {
		this.ifBranch = ifBranch;
	}

	public void setElseBranch(AstList elseBranch) {
		this.elseBranch = elseBranch;
	}

}
